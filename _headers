# Netlify headers config — forces browsers to revalidate JS/CSS so
# freshly deployed code is always picked up, no manual hard-reload needed.

/js/*
  Cache-Control: public, max-age=0, must-revalidate

/css/*
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate
